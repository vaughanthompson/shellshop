/*! 
* elements 
*/

//logo
div.logo
    display:flex
    justify-content: flex-start
    align-items: center
    overflow: hidden
    column-gap: 15px
    

div.logo img
    display: block
    height: 35px
    width: auto
    
.deskLogo
    height: 42px
.deskLogoLarge
    height: 60px
    margin-left: 1em


//cta buttons
.cta
    display: inline-block
    padding: 0.75em 2.5em 0.7em 1em
    margin: marXS 0
    font-weight: 700 !important
    background-color: white
    color: brand1
    position: relative
a.cta:link, a.cta:visited
    color: brand1
    text-decoration: none
a.cta:hover, a.cta:active
    color: white
    background-color: brand3
a.cta:hover::after
    content: '>'
    position: absolute
    right: 0.75em
    top: 0.70em
.rev .cta
    background-color: whiteAlp50
    color: brand1
 .rev a.cta:link, .rev a.cta:visited
    color: brand1
.rev a.cta:hover, .rev a.cta:active
    color: white
    background-color: brand3


.ctaButton, a.ctaButton
    color: brand1
    text-decoration: none
    font-weight: 600
    font-size: 1.1em
    letter-spacing: 0 
    display: inline-block
    background-color: white
    box-shadow: 0 5px 25px 0px blackAlp20
    border-radius: 20px
    //transition: 0.3s
    padding: 17px 20px 18px 20px !important 
    @media phoneRule
        padding: padM padL padM padL !important 
.ctaButton.ctaShop, 
a.ctaButton.ctaShop
    color: brand3
    background-color: brand2
    font-size: 1.2em
div.catItem .ctaButton.ctaShop, 
div.catItem a.ctaButton.ctaShop
    width: 100%
.ctaButton:hover, a.ctaButton:hover
    //display: block
    color: brand2
    background-color: brand3

.ctaButton.activeLink 
    {test}
    border:none !important
    background: none !important
    box-shadow: none
    color: brand1 !important

.ctaButton:hover::after
    width: 100%

.ctaButton > *
    line-height: 1.4em

.oOS, .oOS:hover
    background: none
    box-shadow: none
    color: brand2


.ctaBtn 
    display: inline-block

// icons
.icon 
    background-color: whiteAlp05
    padding: padStd
    font-size: 1.5rem
    display: inline-block
a#toTop
    position: fixed
    bottom: 3vw
    right: 3vw
    text-decoration: none
    opacity: 0
.linkIcon
    color:red
    font-size: 0.8em
    position: absolute
    margin-top: 0.4em
    margin-left: 5px
    margin-right: 5px



//media
.pbVideo
    position: relative
    padding-bottom: 56.25%
    padding-top: 0
    height: 0
.pbVideo iframe 
    position: absolute
    top: 0
    left: 0
    width: 100%
    height: 100%

div.video
    position: relative
div.video > div
    width: 100%
    height: 100%  

.hidden-xs
    display: none
div#vidHolder
    position: absolute
    top: 0
    left: 0px
    width: 100%
    height: 100%
    overflow: hidden
video.hidden-xs
    width: 100%
    height: 100%
    object-fit: cover
@media dtrigger
    video.hidden-xs
        width: 100%
        height: 100%
@media dtrigger
    .hidden-xs
        display: block
       





// lists
ul, ol
    border-bottom:3px solid brand1
    border-top: 1px solid blackAlp10
    padding: 0
    margin: 1em 0
.rev ul,.rev ol
    border-top:1px solid lightGrey
    border-bottom: 2px solid lightGrey
li
    list-style-type: none
    padding: 1em 1em 1em 0
    border-bottom: 1px solid blackAlp10
.rev li
    border-bottom: 1px solid lightGrey
li:last-child
    border-bottom: none
@media desktopRule
    ul, ol
        //
@media lgdesktopRule
    ul, ol
        //
nav ul, nav li
    border:none
    padding:0

footer nav ul
    flex-direction: column
    //{marginT}
ul.iconList
    border: none
ul.iconList li
    padding: 0.1em 1em 0.1em 0
    font-size: 1.2em
    border: none
















// 2025 newthumbs


 a.thumbLink
    transition: 0.5s
    background-size: contain
    background-position: center
    background-repeat: no-repeat
    position: relative
    image-rendering: smooth
    @media effectsBreak
        filter:grayscale(100%)
        @media ttrigger
            transform: scale(0.95)
.designThumbsLarge a.thumbLink
    @media effectsBreak
        @media ttrigger
            transform: scale(0.85)


@media effectsBreak
    a.thumbLink:hover
        filter:none
        transform: scale(1.0)
        image-rendering: smooth
    .designThumbsLarge a.thumbLink:hover
        transform: scale(0.9)

a.thumbLink > h5
    transition: 0.5s
    color: brand9
    font-size: 0.95em
    background-image: url(/images/design/magnify.svg)
    background-repeat: no-repeat
    padding-left: 15px
    line-height: 1.1em
    background-position: bottom left
    background-size: contain
    display: inline-block
    position: absolute
    bottom: 1em
    @media effectsBreak 
        bottom: 0
        
        
.designThumbsLarge a.thumbLink  > h5
    right: 0
    bottom: -2em
    @media effectsBreak
        right: -1em

@media effectsBreak        
    a.thumbLink:hover > h5
        opacity: 0




// 2025 restyle fslightbox
.fslightbox-container
    font-family: "Satoshi-VR", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif !important
    background: rgba(255,255,255,0.98) !important
    font-weight: bold
.fslightbox-slide-btn,
.fslightbox-toolbar
    background: none !important
.fslightbox-slide-number-container
    color: blackAlp50 !important
.fslightbox-svg-path
    fill: blackAlp50 !important
.fslightbox-slash
    background: blackAlp50 !important




div.mobileCart
    position: fixed
    left: 1.5em
    bottom: 2em
    z-index: 10000




/* basic slider */
.imagerySlider div.item > div
    height: 50vh
    border-left:20px solid brand2
.imagerySlider div.item
    border-left:10px solid brand3
.imagerySlider.hero div.item > div
    height: 60vh
@media lgdesktopRule
    .imagerySlider.hero div.item > div
        height: 45vh





/* inpage strip banners */
div.bannerInPage
    padding: padStd*1.25 padM
    text-align: center
    box-shadow: 0px 10px 20px 0px blackAlp20
    border: 1px solid white
    @media phoneRule
        padding: padXL padM
        margin-bottom: 1.5em
div.bannerInPage a
    text-decoration: none